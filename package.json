{
  "name": "emotionflix",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm --workspace server run dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -b && vite build",
    "build:api": "npm --workspace server run build",
    "start": "npm --workspace server run start",
    "seed": "npm --workspace server run seed",
    "seed:verify": "npm --workspace server run seed:verify",
    "lint": "eslint src",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:all": "npm test && npm --workspace server test -- --runInBand",
    "test:integration": "vitest run --testNamePattern=\"Integration\"",
    "test:security": "vitest run --testNamePattern=\"Security\"",
    "test:coverage:full": "npm run test:coverage && npm --workspace server run test:coverage",
    "test:watch:all": "concurrently \"npm run test:watch\" \"npm --workspace server run test:watch\"",
    "test:report": "npm run test:coverage:full && echo 'Test results updated in TESTING.md'"
  },
  "dependencies": {
    "@fontsource/oxygen": "^5.2.8",
    "@types/node": "^24.1.0",
    "axios": "^1.18.1",
    "face-api.js": "^0.22.2",
    "lenis": "^1.3.25",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
