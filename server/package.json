{
  "name": "emotionflix-server",
  "version": "1.0.0",
  "description": "Moodie Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:security": "NODE_OPTIONS=--experimental-vm-modules jest --testNamePattern=\"Security\"",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testNamePattern=\"Integration\"",
    "seed": "tsx src/scripts/seedData.ts",
    "seed:verify": "tsx src/scripts/verifySeedData.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.5.4",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.6",
    "typescript": "~5.7.2"
  }
}
